# Telegram API Credentials
# Get these from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Domain: public host for web setup, generated MCP URL, and media.attachment_download_url (HTTP only).
# Use hostname only (https:// added) or full URL. Placeholder your-domain.com disables attachment URLs.
DOMAIN=your-domain.com

# Server Configuration
# Server mode: stdio (development), http-no-auth (dev server), http-auth (production)
SERVER_MODE=http-auth
# Host binding (auto-adjusts: 127.0.0.1 for stdio, 0.0.0.0 for HTTP)
HOST=0.0.0.0
# Service port
PORT=8000

# Session Management
# LRU cache limit for concurrent sessions
MAX_ACTIVE_SESSIONS=10
# Custom session directory (defaults to ~/.config/fast-mcp-telegram/)
SESSION_DIR=

# Web Setup Configuration
# TTL for temporary setup sessions (seconds)
SETUP_SESSION_TTL_SECONDS=900

# How long a minted attachment UUID remains valid (seconds). In-memory; restart invalidates all.
ATTACHMENT_TICKET_TTL_SECONDS=3600

# Logging Configuration
LOG_LEVEL=INFO

# VDS Deployment (for remote server deployment)
# Uncomment and configure for remote deployment
# VDS_USER=your_server_user
# VDS_HOST=your.server.com
# VDS_PROJECT_PATH=/path/to/deployment

# Phone number is provided via CLI --phone-number option during setup
# for better security and flexibility
